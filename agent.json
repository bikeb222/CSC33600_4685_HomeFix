      "seed": "code/server/seed/seed.sql",
      "eer_current": "doc/EER/Homefix_EER_v3.drawio",
      "tables": [
        "Users",
        "Receivers",
        "Providers",
        "Managers",
        "Provider_Unavailable_Blocks",
        "Services",
        "Provider_Services",
        "Addresses",
        "Appointments",
        "Payments",
        "Reviews"
