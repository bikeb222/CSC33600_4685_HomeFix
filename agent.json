      "views": [
        "vw_tableau_appointment_report",
        "vw_tableau_payment_report",
        "vw_tableau_provider_performance"
      ]
    }
  },
  "business_rules": {
    "roles": {
      "manager": "Can manage users, receivers, providers, services, appointments, payments, reports, and provider skill approvals. Cannot create reviews.",
      "receiver": "Can book appointments for self, manage own addresses/profile, recharge own wallet, pay completed appointments, and review providers.",
      "provider": "Cannot create appointments. Can accept/reject assigned appointments, move accepted appointments to in_progress, set actual hours, request skills, manage own unavailable blocks, and review receivers."
    },
    "provider_services": {
      "rule": "Provider skills are records in Provider_Services. Provider-created skills are pending until manager approval.",
      "bookable_condition": "Provider_Services.approval_status must be approved.",
      "frontend_location": "code/client/src/pages/ServicesPage.jsx"
    },
    "provider_schedule": {
      "normal_hours": "Monday-Friday 08:00-17:00 local time",
      "surcharges": {
        "standard_hours": 0,
        "after_hours_weekday": 0.2,
        "weekend_daytime": 0.1,
        "weekend_after_hours": 0.3
      },
      "manual_unavailable_table": "Provider_Unavailable_Blocks",
      "conflict_rule": "Appointment creation rejects overlap with pending, accepted, or in_progress appointments for the same provider, and rejects overlap with Provider_Unavailable_Blocks.",
      "rate_snapshot": "Appointments.hourly_rate_at_booking stores the final hourly rate after schedule surcharge."
    },
    "appointment_lifecycle": [
      "receiver_or_manager_creates_pending",
      "provider_accepts_or_rejects",
      "provider_can_move_accepted_to_in_progress",
      "provider_or_manager_sets_actual_hours_after_acceptance",
      "receiver_confirms_completed_from_accepted_or_in_progress",
      "payment_can_be_created_after_completed_and_actual_hours",
      "receiver_and_provider_can_review_each_other_once"
    ],
    "payments": {
      "wallet": "Receivers.wallet_balance stores funds.",
      "recharge": "Receivers can recharge self. Managers can recharge any receiver.",
      "payment_amount": "Default payment amount is Appointments.actual_total.",
      "receiver_payment": "Receiver-created payments are forced to paid and deduct wallet balance.",
      "refund": "Manager changing a paid payment to refunded returns funds to the receiver wallet."
    },
    "reviews": {
      "directions": [
        "receiver_to_provider",
        "provider_to_receiver"
      ],
      "restriction": "Only completed appointments can be reviewed. Managers cannot create reviews. Unique constraint prevents duplicate review_direction per appointment."
    }
  },
  "api": {
    "auth_required": "All endpoints except /api/health, /api/auth/login, and public auth/register require Bearer JWT.",
    "important_endpoints": {
      "auth": [
        "POST /api/auth/login",
        "GET /api/auth/me"
      ],
      "providers": [
        "GET /api/providers",
        "GET /api/providers?serviceId=:serviceId",
        "GET /api/providers/:id/services",
        "POST /api/providers/:id/services",
        "GET /api/providers/service-approvals",
        "PUT /api/providers/:providerId/services/:serviceId/review",
        "GET /api/providers/:id/unavailable-blocks",
        "POST /api/providers/:id/unavailable-blocks",
        "DELETE /api/providers/:id/unavailable-blocks/:blockId",
        "GET /api/providers/:providerId/unavailable-times"
      ],
      "appointments": [
        "GET /api/appointments",
        "POST /api/appointments",
        "PUT /api/appointments/:id/status",
        "PUT /api/appointments/:id/actual-hours"
      ],
      "payments": [
        "GET /api/payments",
        "POST /api/payments",
        "PUT /api/payments/:id/status",
        "POST /api/wallet/recharge",
        "POST /api/receivers/:receiverId/recharge"
      ],
      "reviews": [
        "GET /api/reviews",
        "POST /api/reviews",
        "DELETE /api/reviews/:id"
      ],
      "reports": [
        "GET /api/reports/appointments",
        "GET /api/reports/payments",
        "GET /api/reports/provider-performance",
        "GET /api/reports/appointments/export",
        "GET /api/reports/payments/export",
        "GET /api/reports/provider-performance/export"
      ]
    }
  },
