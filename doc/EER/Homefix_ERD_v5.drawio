          </mxGeometry>
        </mxCell>
        <mxCell id="rules" value="&lt;b&gt;Key Business Rules&lt;/b&gt;&lt;br&gt;&lt;hr&gt;1. Users specialize into exactly one role row by user.role.&lt;br&gt;2. Provider skills require manager approval before booking.&lt;br&gt;3. Provider appointments cannot overlap pending/accepted/in_progress appointments.&lt;br&gt;4. Provider unavailable blocks also prevent overlapping appointments.&lt;br&gt;5. Booking rate snapshot includes schedule surcharge: weekday after-hours +20%, weekend +10%, both +30%.&lt;br&gt;6. Actual payment requires completed appointment and actual_hours.&lt;br&gt;7. Reviews are only receiver-provider or provider-receiver, one per direction." style="rounded=0;whiteSpace=wrap;html=1;align=left;verticalAlign=top;spacing=10;fontSize=14;fontFamily=Verdana;fillColor=none;strokeColor=#000000;" parent="1" vertex="1">
          <mxGeometry x="1390" y="1620" width="560" height="220" as="geometry" />
        </mxCell>
        <mxCell id="views" value="&lt;b&gt;Reporting Views&lt;/b&gt;&lt;br&gt;&lt;hr&gt;vw_tableau_appointment_report&lt;br&gt;vw_tableau_payment_report&lt;br&gt;vw_tableau_provider_performance&lt;br&gt;&lt;br&gt;Used by Reports page and Tableau/Excel export flow." style="rounded=0;whiteSpace=wrap;html=1;align=left;verticalAlign=top;spacing=10;fontSize=14;fontFamily=Verdana;fillColor=none;strokeColor=#000000;" parent="1" vertex="1">
          <mxGeometry x="1990" y="1590" width="480" height="180" as="geometry" />
        </mxCell>
        <mxCell id="revenue_streams" value="&lt;b&gt;Revenue Streams&lt;/b&gt;&lt;br&gt;&lt;hr&gt;1. Receivers pay completed appointments through Payments.total_amount.&lt;br&gt;2. Homefix earns platform commission through Payments.commission_fee.&lt;br&gt;3. Providers receive net payout through Payments.provider_payout.&lt;br&gt;4. Premium booking windows are represented by schedule_surcharge_rate and schedule_surcharge_reason.&lt;br&gt;5. Wallet balance supports prepaid receiver funds and manager recharge operations." style="rounded=0;whiteSpace=wrap;html=1;align=left;verticalAlign=top;spacing=10;fontSize=14;fontFamily=Verdana;fillColor=none;strokeColor=#000000;" parent="1" vertex="1">
          <mxGeometry x="1990" y="1790" width="480" height="220" as="geometry" />
        </mxCell>
        <mxCell id="normalization_note" value="&lt;b&gt;Normalization Note&lt;/b&gt;&lt;br&gt;&lt;hr&gt;The design satisfies at least 2NF: every table uses atomic attributes, each non-key attribute depends on the whole primary key, and many-to-many data such as provider skills is separated into Provider_Services." style="rounded=0;whiteSpace=wrap;html=1;align=left;verticalAlign=top;spacing=10;fontSize=14;fontFamily=Verdana;fillColor=none;strokeColor=#000000;" parent="1" vertex="1">
          <mxGeometry x="1390" y="1860" width="560" height="140" as="geometry" />
        </mxCell>
        <mxCell id="ai_assistant_note" value="&lt;b&gt;AI Assistant Boundary&lt;/b&gt;&lt;br&gt;&lt;hr&gt;Receiver AI Customer Service uses FAQ grounding plus receiver-scoped safe queries for appointments, addresses, payments, reviews, and public provider/service data.&lt;br&gt;&lt;br&gt;Manager AI Assistant uses read-only safe analytics queries for revenue, commission, payment status, appointment status, provider performance, service popularity, and operational warnings.&lt;br&gt;&lt;br&gt;AI never executes generated SQL and API keys remain in backend environment variables." style="rounded=0;whiteSpace=wrap;html=1;align=left;verticalAlign=top;spacing=10;fontSize=14;fontFamily=Verdana;fillColor=none;strokeColor=#000000;" parent="1" vertex="1">
